		formatString: 0
		lineageTag: 079d8b74-f4e4-4c1c-bf91-35cd340ac082
		sourceLineageTag: Claim_Type_ID
		summarizeBy: none
		sourceColumn: Claim_Type_ID

		annotation SummarizationSetBy = Automatic

	/// The descriptive name of the claim type category, such as Collision, Theft, Comprehensive, or Vandalism.
	column ClaimTypeName
		dataType: string
		lineageTag: f5838716-f2e0-495b-a3fa-51a5e0f30573
		sourceLineageTag: Claim_Type_Name
		summarizeBy: none
